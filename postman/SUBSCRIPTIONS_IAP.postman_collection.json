          },
          {
            "key": "Content-Type",
            "value": "application/json",
            "type": "text"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{}"
        },
        "url": {
          "raw": "{{BASE_URL}}/api/subscriptions/restore",
          "host": [
            "{{BASE_URL}}"
          ],
          "path": [
            "api",
            "subscriptions",
            "restore"
          ]
        }
      }
    },
    {
      "name": "Cancel Subscription (Apple-managed)",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{FIREBASE_ID_TOKEN}}",
            "type": "text"
          },
          {
            "key": "Content-Type",
            "value": "application/json",
            "type": "text"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{}"
        },
        "url": {
          "raw": "{{BASE_URL}}/api/subscriptions/cancel",
          "host": [
            "{{BASE_URL}}"
          ],
          "path": [
            "api",
            "subscriptions",
            "cancel"
          ]
        }
      }
    },
    {
      "name": "App Store Webhook (test payload)",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json",
            "type": "text"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"signedPayload\": \"{{APPLE_SIGNED_PAYLOAD}}\"\n}"
        },
        "url": {
          "raw": "{{BASE_URL}}/api/subscriptions/webhook",
          "host": [
            "{{BASE_URL}}"
          ],
          "path": [
            "api",
            "subscriptions",
            "webhook"
          ]
        }
      }
    },
    {
      "name": "Scan Create (Trial limit test)",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{FIREBASE_ID_TOKEN}}",
            "type": "text"
          }
        ],
        "body": {
          "mode": "formdata",
          "formdata": [
            {
              "key": "petId",
              "value": "{{PET_ID}}",
              "type": "text"
            },
            {
              "key": "mediaType",
              "value": "image",
              "type": "text"
            },
            {
              "key": "file",
              "type": "file",
              "src": "{{SAMPLE_IMAGE_PATH}}"
            }
          ]
        },
        "url": {
          "raw": "{{BASE_URL}}/api/scans",
          "host": [
            "{{BASE_URL}}"
          ],
          "path": [
            "api",
            "scans"
          ]
        }
      }
    },
    {
      "name": "Admin List Subscriptions",
      "request": {
        "method": "GET",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{ADMIN_FIREBASE_ID_TOKEN}}",
            "type": "text"
          }
        ],
        "url": {
          "raw": "{{BASE_URL}}/api/subscriptions/admin/list?uid={{TARGET_UID}}",
          "host": [
            "{{BASE_URL}}"
          ],
          "path": [
            "api",
            "subscriptions",
            "admin",
            "list"
          ],
          "query": [
            {
              "key": "uid",
              "value": "{{TARGET_UID}}"
            }
          ]
        }
      }
    }
  ],
