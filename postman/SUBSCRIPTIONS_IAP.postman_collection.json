{
  "info": {
    "name": "PetMood - Subscriptions IAP APIs",
    "_postman_id": "a5d2f5dc-2be0-42c2-a894-95c6a70b5999",
    "description": "Subscription APIs: plans, verify-receipt, status, restore, cancel, webhook, admin list, plus trial scan-limit test.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "List Plans",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{BASE_URL}}/api/subscriptions/plans",
          "host": [
            "{{BASE_URL}}"
          ],
          "path": [
            "api",
            "subscriptions",
            "plans"
          ]
        }
      }
    },
    {
      "name": "Verify Receipt (transaction_id only)",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{FIREBASE_ID_TOKEN}}",
            "type": "text"
          },
          {
            "key": "Content-Type",
            "value": "application/json",
            "type": "text"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"product_id\": \"com.petmood.premium.monthly\",\n  \"transaction_id\": \"{{TRANSACTION_ID}}\",\n  \"original_transaction_id\": \"{{ORIGINAL_TRANSACTION_ID}}\"\n}"
        },
        "url": {
          "raw": "{{BASE_URL}}/api/subscriptions/verify-receipt",
          "host": [
            "{{BASE_URL}}"
          ],
          "path": [
            "api",
            "subscriptions",
            "verify-receipt"
          ]
        }
      }
    },
    {
      "name": "Verify Receipt (with signed_transaction_jws)",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{FIREBASE_ID_TOKEN}}",
            "type": "text"
          },
          {
            "key": "Content-Type",
            "value": "application/json",
            "type": "text"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"product_id\": \"com.petmood.premium.monthly\",\n  \"transaction_id\": \"{{TRANSACTION_ID}}\",\n  \"original_transaction_id\": \"{{ORIGINAL_TRANSACTION_ID}}\",\n  \"signed_transaction_jws\": \"{{SIGNED_TRANSACTION_JWS}}\"\n}"
        },
        "url": {
          "raw": "{{BASE_URL}}/api/subscriptions/verify-receipt",
          "host": [
            "{{BASE_URL}}"
          ],
          "path": [
            "api",
            "subscriptions",
            "verify-receipt"
          ]
        }
      }
    },
    {
      "name": "Subscription Status",
      "request": {
        "method": "GET",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{FIREBASE_ID_TOKEN}}",
            "type": "text"
          }
        ],
        "url": {
          "raw": "{{BASE_URL}}/api/subscriptions/status",
          "host": [
            "{{BASE_URL}}"
          ],
          "path": [
            "api",
            "subscriptions",
            "status"
          ]
        }
      }
    },
